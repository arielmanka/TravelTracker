# TravelTracker Environment Configuration
# Copy this file to '.env' and fill in your details

# LLM API Config (Cloud providers - optional, leave blank if not used)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Local Ollama connection configuration (default: host.docker.internal:11434 inside docker)
OLLAMA_API_URL=http://host.docker.internal:11434
# If running backend outside docker (for local testing):
# OLLAMA_API_URL=http://localhost:11434
